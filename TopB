    const PRED_OPTS = [
      {key:"ms1",label:"MS 1",color:"#16a34a"},
      {key:"msx",label:"MS X",color:"#d97706"},
      {key:"ms2",label:"MS 2",color:"#dc2626"},
      {key:"kg", label:"KG Var",color:"#7c3aed"},
      {key:"ust",label:"2.5 Üst",color:"#0891b2"},
    ];
    const PC = k => PRED_OPTS.find(p=>p.key===k)?.color||"#888";
    const PL = k => PRED_OPTS.find(p=>p.key===k)?.label||k;

    const SEED = {
      101:[
        {id:1,nick:"DerbiUstası",pred:"ms1",msg:"Osimhen bu gece sahnede olacak 🔥",ts:Date.now()-290000,pro:true},
        {id:2,nick:"SarıKanarya99",pred:"ms2",msg:"Fenerbahçe deplasmanda daha iyi bu sezon",ts:Date.now()-211000,pro:false},
