      const hc=col(match.home), ac=col(match.away);
      return (
        <div style={{height:"100%",display:"flex",flexDirection:"column",background:C.bg}}>
          <div style={{display:"flex",padding:"10px 12px",gap:6,borderBottom:"1px solid "+C.border,background:C.card,flexShrink:0,overflowX:"auto"}}>
