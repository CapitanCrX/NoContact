                  <span style={{fontSize:11,fontWeight:700,color:ac}}>{match.away}</span>
                </div>
              </div>
            )}
            {section==="form" && (
              <div>
                <div style={{fontSize:10,fontWeight:700,color:C.muted,letterSpacing:1.2,marginBottom:12}}>SON 5 MAÇ FORMU</div>
                <div style={{background:C.card,borderRadius:12,padding:"14px 16px",marginBottom:18,border:"1px solid "+C.border}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
                    <div style={{display:"flex",alignItems:"center",gap:8}}>
                      <TeamLogo name={match.home} size={26}/>
                      <span style={{fontSize:12,fontWeight:800,color:hc}}>{match.home}</span>
                    </div>
                    <div style={{display:"flex",alignItems:"center",gap:8}}>
                      <span style={{fontSize:12,fontWeight:800,color:ac}}>{match.away}</span>
                      <TeamLogo name={match.away} size={26}/>
                    </div>
                  </div>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                    <div style={{display:"flex",gap:4}}>{match.form.home.map((r,i)=><FormDot key={i} r={r}/>)}</div>
                    <span style={{fontSize:12,color:C.muted}}>vs</span>
                    <div style={{display:"flex",gap:4}}>{match.form.away.map((r,i)=><FormDot key={i} r={r}/>)}</div>
                  </div>
                </div>
                <div style={{fontSize:10,fontWeight:700,color:C.muted,letterSpacing:1.2,marginBottom:12}}>ÖNCEKİ KARŞILAŞMALAR</div>
                {match.h2h.map((g,i)=>(
                  <div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 12px",borderRadius:10,background:C.card,border:"1px solid "+C.border,marginBottom:6}}>
                    <span style={{fontSize:10,color:C.muted,minWidth:58,fontWeight:600}}>{g.d}</span>
                    <span style={{flex:1,fontSize:12,fontWeight:700,color:C.text,textAlign:"right"}}>{g.h}</span>
                    <span style={{padding:"3px 10px",background:C.text,color:"#fff",borderRadius:6,fontSize:13,fontWeight:900,fontFamily:"'Oswald',sans-serif",minWidth:52,textAlign:"center"}}>{g.s}</span>
                    <span style={{flex:1,fontSize:12,fontWeight:700,color:C.text}}>{g.a}</span>
                  </div>
                ))}
              </div>
            )}
            {section==="lineup" && (
              <div>
                <div style={{fontSize:10,fontWeight:700,color:C.muted,letterSpacing:1.2,marginBottom:12}}>İLK 11 KADRO</div>
                {match.lineup.home.length===0 ? (
                  <div style={{textAlign:"center",padding:"50px 0",color:C.muted,fontSize:14}}>⏳ Kadro henüz açıklanmadı</div>
                ) : (
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                    <div>
                      <div style={{fontSize:11,fontWeight:800,color:hc,marginBottom:8,padding:"5px 10px",background:hc+"22",borderRadius:8,textAlign:"center",fontFamily:"'Oswald',sans-serif",border:"1px solid "+hc+"44"}}>{match.home.toUpperCase()}</div>
                      {match.lineup.home.map((p,i)=>(
                        <div key={i} style={{display:"flex",alignItems:"center",gap:7,padding:"6px 9px",borderRadius:7,marginBottom:3,background:C.card,border:"1px solid "+(i===0?hc+"50":C.border)}}>
                          <span style={{width:18,height:18,borderRadius:"50%",background:i===0?hc:"#e5e7eb",color:i===0?"#fff":"#6b7280",display:"flex",alignItems:"center",justifyContent:"center",fontSize:8,fontWeight:800,flexShrink:0}}>{i+1}</span>
                          <span style={{fontSize:11,color:i===0?C.text:"#6b7280",fontFamily:"'Nunito Sans',sans-serif",fontWeight:i===0?700:500,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p}</span>
                        </div>
                      ))}
                    </div>
                    <div>
                      <div style={{fontSize:11,fontWeight:800,color:ac,marginBottom:8,padding:"5px 10px",background:ac+"22",borderRadius:8,textAlign:"center",fontFamily:"'Oswald',sans-serif",border:"1px solid "+ac+"44"}}>{match.away.toUpperCase()}</div>
                      {match.lineup.away.map((p,i)=>(
                        <div key={i} style={{display:"flex",alignItems:"center",gap:7,padding:"6px 9px",borderRadius:7,marginBottom:3,background:C.card,border:"1px solid "+(i===0?ac+"50":C.border)}}>
                          <span style={{width:18,height:18,borderRadius:"50%",background:i===0?ac:"#e5e7eb",color:i===0?"#fff":"#6b7280",display:"flex",alignItems:"center",justifyContent:"center",fontSize:8,fontWeight:800,flexShrink:0}}>{i+1}</span>
                          <span style={{fontSize:11,color:i===0?C.text:"#6b7280",fontFamily:"'Nunito Sans',sans-serif",fontWeight:i===0?700:500,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      );
    }

    function BottomSheet({match,onClose}) {
      const [tab,setTab]=useState("stats");
      const isLive=match.status==="live";
      useEffect(()=>{document.body.style.overflow="hidden";return()=>{document.body.style.overflow="";};},[]);
      return (
        <div style={{position:"fixed",inset:0,zIndex:900,display:"flex",flexDirection:"column"}}>
          <div style={{flex:"0 0 48px",background:"rgba(0,0,0,.35)"}} onClick={onClose}/>
          <div style={{flex:1,background:C.bg,borderRadius:"18px 18px 0 0",display:"flex",flexDirection:"column",overflow:"hidden",boxShadow:"0 -6px 30px rgba(0,0,0,.12)"}}>
            <div style={{display:"flex",justifyContent:"center",padding:"10px 0 4px",flexShrink:0,cursor:"pointer"}} onClick={onClose}>
              <div style={{width:36,height:4,borderRadius:2,background:C.border}}/>
            </div>
            <div style={{flexShrink:0,background:C.card,borderBottom:"1px solid "+C.border,padding:"14px 20px 18px",position:"relative",overflow:"hidden"}}>
              <img src={logo(match.home)||""} alt="" style={{position:"absolute",left:-20,top:"50%",transform:"translateY(-50%)",width:130,height:130,objectFit:"contain",opacity:.07,pointerEvents:"none"}}/>
              <img src={logo(match.away)||""} alt="" style={{position:"absolute",right:-20,top:"50%",transform:"translateY(-50%)",width:130,height:130,objectFit:"contain",opacity:.07,pointerEvents:"none"}}/>
              <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",gap:8,position:"relative"}}>
                <div style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:8}}>
                  <TeamLogo name={match.home} size={56}/>
                  <span style={{fontSize:13,fontWeight:900,color:C.text,fontFamily:"'Oswald',sans-serif",textAlign:"center",lineHeight:1.2}}>{match.home}</span>
                </div>
                <div style={{textAlign:"center",flexShrink:0}}>
                  {match.score ? (
                    <div>
                      <div style={{fontSize:44,fontWeight:900,color:C.text,fontFamily:"'Oswald',sans-serif",letterSpacing:-2,lineHeight:1}}>
                        {match.score[0]}<span style={{color:"#d1d5db",margin:"0 4px"}}>–</span>{match.score[1]}
                      </div>
                      {isLive && (
                        <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:5,marginTop:5}}>
                          <div style={{width:8,height:8,borderRadius:"50%",background:C.live,animation:"lp 1s infinite"}}/>
                          <span style={{fontSize:13,fontWeight:800,color:C.live,fontFamily:"'Oswald',sans-serif"}}>{match.minute}'</span>
                        </div>
                      )}
                      {match.status==="finished"&&<div style={{fontSize:11,color:C.muted,marginTop:4,fontWeight:700}}>MS</div>}
                    </div>
                  ) : (
                    <div>
                      <div style={{fontSize:28,fontWeight:900,color:C.muted,fontFamily:"'Oswald',sans-serif"}}>{match.time}</div>
                      <div style={{fontSize:10,color:C.muted,marginTop:2}}>BAŞLAMADI</div>
                    </div>
                  )}
                </div>
                <div style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:8}}>
                  <TeamLogo name={match.away} size={56}/>
                  <span style={{fontSize:13,fontWeight:900,color:C.text,fontFamily:"'Oswald',sans-serif",textAlign:"center",lineHeight:1.2}}>{match.away}</span>
                </div>
              </div>
            </div>
            <div style={{display:"flex",background:C.card,borderBottom:"1px solid "+C.border,flexShrink:0}}>
              {[{id:"stats",label:"📊 İstatistik"},{id:"chat",label:"💬 Sohbet"}].map(t=>(
                <button key={t.id} onClick={()=>setTab(t.id)} style={{flex:1,padding:"13px 0",fontSize:13,fontWeight:800,color:tab===t.id?C.accent:C.muted,background:"none",border:"none",cursor:"pointer",borderBottom:tab===t.id?"2.5px solid "+C.accent:"2.5px solid transparent",marginBottom:-1,fontFamily:"'Nunito Sans',sans-serif"}}>{t.label}</button>
              ))}
            </div>
            <div style={{flex:1,overflow:"hidden"}}>
              {tab==="stats"&&<StatsTab match={match}/>}
              {tab==="chat"&&<ChatPanel matchId={match.id}/>}
            </div>
          </div>
        </div>
      );
    }

    function MatchRow({match}) {
      const [open,setOpen]=useState(false);
      const isLive=match.status==="live";
      const isDone=match.status==="finished";
      return (
        <>
          <div style={{display:"flex",alignItems:"stretch",borderBottom:"1px solid "+C.border,background:C.card,position:"relative",minHeight:70,overflow:"hidden"}}
            onMouseEnter={e=>e.currentTarget.style.background="#f5f8ff"}
            onMouseLeave={e=>e.currentTarget.style.background=C.card}
          >
            {isLive&&<div style={{position:"absolute",left:0,top:0,bottom:0,width:3,background:C.live}}/>}
            <div style={{width:54,flexShrink:0,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:"8px 4px",borderRight:"1px solid "+C.border,background:isLive?"#fef2f2":C.sub,zIndex:1}}>
              {isLive ? (
                <div style={{display:"flex",flexDirection:"column",alignItems:"center"}}>
                  <div style={{width:7,height:7,borderRadius:"50%",background:C.live,marginBottom:4,animation:"lp 1s infinite"}}/>
                  <div style={{fontSize:15,fontWeight:900,color:C.live,fontFamily:"'Oswald',sans-serif",lineHeight:1}}>{match.minute}'</div>
                </div>
              ) : isDone ? (
                <div style={{fontSize:10,fontWeight:700,color:C.muted}}>MS</div>
              ) : (
                <div style={{fontSize:13,fontWeight:700,color:"#374151",fontFamily:"'Oswald',sans-serif",textAlign:"center"}}>{match.time}</div>
              )}
            </div>
            <div style={{flex:1,padding:"8px 12px",display:"flex",flexDirection:"column",justifyContent:"center",gap:7,overflow:"hidden",position:"relative",zIndex:1}}>
              {/* Home */}
              <div style={{display:"flex",alignItems:"center",gap:9,position:"relative"}}>
                <TeamLogo name={match.home} size={22} style={{borderRadius:4,flexShrink:0}}/>
                <div style={{flex:1,position:"relative",overflow:"hidden",display:"flex",alignItems:"center"}}>
                  <img src={logo(match.home)||""} alt="" style={{position:"absolute",left:0,top:"50%",transform:"translateY(-50%)",height:32,width:32,objectFit:"contain",opacity:.12,pointerEvents:"none"}}/>
                  <span style={{fontSize:14,fontWeight:800,color:C.text,fontFamily:"'Nunito Sans',sans-serif",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",position:"relative",zIndex:1,paddingLeft:2}}>{match.home}</span>
                </div>
                {match.score!==null&&<span style={{fontSize:20,fontWeight:900,color:C.text,fontFamily:"'Oswald',sans-serif",minWidth:20,textAlign:"center"}}>{match.score[0]}</span>}
              </div>
              {/* Away */}
              <div style={{display:"flex",alignItems:"center",gap:9,position:"relative"}}>
                <TeamLogo name={match.away} size={22} style={{borderRadius:4,flexShrink:0}}/>
                <div style={{flex:1,position:"relative",overflow:"hidden",display:"flex",alignItems:"center"}}>
                  <img src={logo(match.away)||""} alt="" style={{position:"absolute",left:0,top:"50%",transform:"translateY(-50%)",height:32,width:32,objectFit:"contain",opacity:.12,pointerEvents:"none"}}/>
                  <span style={{fontSize:14,fontWeight:800,color:C.text,fontFamily:"'Nunito Sans',sans-serif",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",position:"relative",zIndex:1,paddingLeft:2}}>{match.away}</span>
                </div>
                {match.score!==null&&<span style={{fontSize:20,fontWeight:900,color:C.text,fontFamily:"'Oswald',sans-serif",minWidth:20,textAlign:"center"}}>{match.score[1]}</span>}
              </div>
            </div>
            <button onClick={()=>setOpen(true)} style={{width:46,flexShrink:0,background:"none",border:"none",borderLeft:"1px solid "+C.border,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",zIndex:1}}>
              <span style={{fontSize:24,color:"#d1d5db",lineHeight:1}}>›</span>
            </button>
          </div>
          {open&&<BottomSheet match={match} onClose={()=>setOpen(false)}/>}
        </>
      );
    }

    function GeneralChatScreen({onClose}) {
      useEffect(()=>{document.body.style.overflow="hidden";return()=>{document.body.style.overflow="";};},[]);
      return (
        <div style={{position:"fixed",inset:0,zIndex:900,background:C.bg,display:"flex",flexDirection:"column"}}>
          <div style={{height:54,background:C.card,borderBottom:"1px solid "+C.border,display:"flex",alignItems:"center",padding:"0 16px",gap:12,flexShrink:0}}>
            <button onClick={onClose} style={{width:36,height:36,borderRadius:"50%",border:"1px solid "+C.border,background:C.sub,color:C.text,fontSize:20,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>‹</button>
            <span style={{fontSize:22}}>⚽</span>
            <div>
              <div style={{fontSize:15,fontWeight:900,color:C.text,fontFamily:"'Oswald',sans-serif",letterSpacing:.5}}>GENEL SOHBET</div>
              <div style={{fontSize:11,color:C.muted}}>Tüm maçlar hakkında</div>
            </div>
            <div style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:5}}>
              <div style={{width:7,height:7,borderRadius:"50%",background:C.green,boxShadow:"0 0 5px "+C.green}}/>
              <span style={{fontSize:11,color:C.muted,fontWeight:700}}>247</span>
            </div>
          </div>
          <div style={{flex:1,overflow:"hidden"}}><ChatPanel matchId={null}/></div>
        </div>
      );
    }

    function App() {
      const [navPage,setNavPage]=useState("home");
      const liveCount=LEAGUES.flatMap(l=>l.matches).filter(m=>m.status==="live").length;
      return (
        <div style={{background:C.bg,minHeight:"100vh",fontFamily:"'Nunito Sans',system-ui,sans-serif",maxWidth:430,margin:"0 auto",position:"relative"}}>
          <div style={{background:C.card,borderBottom:"1px solid "+C.border,padding:"0 16px",height:52,display:"flex",alignItems:"center",gap:10,position:"sticky",top:0,zIndex:100,boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
            <div style={{fontFamily:"'Oswald',sans-serif",fontSize:22,fontWeight:700,color:C.accent,letterSpacing:1}}>TOP BİZDE</div>
            {liveCount>0&&(
              <div style={{display:"flex",alignItems:"center",gap:4,background:"#fef2f2",border:"1px solid #fecaca",padding:"3px 8px",borderRadius:6}}>
                <div style={{width:6,height:6,borderRadius:"50%",background:C.live,animation:"lp 1s infinite"}}/>
                <span style={{fontSize:10,fontWeight:800,color:C.live,letterSpacing:.5,fontFamily:"'Oswald',sans-serif"}}>{liveCount} CANLI</span>
              </div>
            )}
            <div style={{flex:1}}/>
            <button onClick={()=>setNavPage("chat")} style={{width:40,height:40,borderRadius:"50%",background:"linear-gradient(135deg,#dbeafe,#bfdbfe)",border:"1.5px solid #93c5fd",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,position:"relative"}}>
              ⚽
              <div style={{position:"absolute",top:-2,right:-2,width:12,height:12,borderRadius:"50%",background:C.green,border:"2px solid "+C.card}}/>
            </button>
          </div>
          <div style={{background:C.card,borderBottom:"1px solid "+C.border,overflowX:"auto",display:"flex",padding:"0 12px"}}>
            {["Tümü","Canlı","Süper Lig","UCL","Premier L.","La Liga"].map((t,i)=>(
              <div key={t} style={{padding:"10px 12px",whiteSpace:"nowrap",fontSize:12,fontWeight:700,cursor:"pointer",color:i===0?C.accent:C.muted,borderBottom:i===0?"2px solid "+C.accent:"2px solid transparent",flexShrink:0,fontFamily:"'Nunito Sans',sans-serif"}}>{t}</div>
            ))}
          </div>
          <div style={{paddingBottom:76}}>
            {LEAGUES.map(league=>(
              <div key={league.id} style={{marginBottom:8}}>
                <div style={{display:"flex",alignItems:"center",gap:8,padding:"8px 14px",background:"#eef2ff",borderTop:"1px solid "+C.border,borderBottom:"1px solid "+C.border}}>
                  <span style={{fontSize:15}}>{league.flag}</span>
                  <span style={{fontSize:12,fontWeight:900,color:"#1e3a8a",fontFamily:"'Oswald',sans-serif",letterSpacing:.8}}>{league.name}</span>
                  <span style={{marginLeft:"auto",fontSize:11,color:"#6b7280",fontWeight:600}}>{league.matches[0]&&league.matches[0].time}</span>
                </div>
                {league.matches.map(m=><MatchRow key={m.id} match={m}/>)}
              </div>
            ))}
          </div>
          <div style={{position:"fixed",bottom:0,left:"50%",transform:"translateX(-50%)",width:"100%",maxWidth:430,background:C.card,borderTop:"1px solid "+C.border,display:"flex",zIndex:200,boxShadow:"0 -2px 10px rgba(0,0,0,.06)"}}>
            {[{id:"home",icon:"⚽",label:"Maçlar"},{id:"live",icon:"📡",label:"Canlı"},{id:"chat",icon:"💬",label:"Sohbet"},{id:"profile",icon:"👤",label:"Profil"}].map(tab=>(
              <button key={tab.id} onClick={()=>setNavPage(tab.id==="chat"?"chat":tab.id)} style={{flex:1,padding:"10px 0 8px",display:"flex",flexDirection:"column",alignItems:"center",gap:3,background:"none",border:"none",cursor:"pointer"}}>
                <span style={{fontSize:20}}>{tab.icon}</span>
                <span style={{fontSize:10,fontWeight:700,color:navPage===tab.id?C.accent:C.muted,fontFamily:"'Nunito Sans',sans-serif"}}>{tab.label}</span>
                {navPage===tab.id&&<div style={{width:18,height:2,borderRadius:1,background:C.accent}}/>}
              </button>
            ))}
          </div>
          {navPage==="chat"&&<GeneralChatScreen onClose={()=>setNavPage("home")}/>}
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById("root"));
    root.render(<App/>);
  </script>

</body>
</html>
