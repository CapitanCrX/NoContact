    function timeAgo(ts) {
      const s=Math.floor((Date.now()-ts)/1000);
      if(s<60) return s+"s";
      if(s<3600) return Math.floor(s/60)+"dk";
      return Math.floor(s/3600)+"sa";
    }

    function TeamLogo({name, size=28, style={}}) {
      const src=logo(name);
      if(!src) return <div style={{width:size,height:size,borderRadius:4,background:"#e5e7eb",display:"flex",alignItems:"center",justifyContent:"center",fontSize:size*0.5,flexShrink:0,...style}}>⚽</div>;
      return <img src={src} width={size} height={size} alt={name} style={{objectFit:"contain",flexShrink:0,...style}} onError={e=>e.target.style.opacity=0}/>;
    }

    function FormDot({r}) {
      const bg=r==="G"?"#16a34a":r==="B"?"#dc2626":"#d97706";
      return <div style={{width:26,height:26,borderRadius:"50%",background:bg,display:"flex",alignItems:"center",justifyContent:"center",fontSize:10,fontWeight:800,color:"#fff",flexShrink:0}}>{r}</div>;
    }

    function StatBar({label,h,a}) {
      const t=(h+a)||1;
      return (
        <div style={{marginBottom:13}}>
          <div style={{display:"flex",justifyContent:"space-between",marginBottom:4}}>
            <span style={{fontSize:13,fontWeight:800,color:C.text}}>{h}</span>
            <span style={{fontSize:11,color:C.muted,fontWeight:600}}>{label}</span>
            <span style={{fontSize:13,fontWeight:800,color:C.text}}>{a}</span>
          </div>
          <div style={{height:5,background:C.border,borderRadius:3,overflow:"hidden",display:"flex"}}>
            <div style={{width:(h/t*100)+"%",background:"linear-gradient(90deg,#2563eb,#60a5fa)",borderRadius:3}}/>
            <div style={{flex:1,background:"linear-gradient(90deg,#ef4444,#f87171)"}}/>
          </div>
        </div>
      );
    }

    function ChatPanel({matchId}) {
      const key=matchId||"general";
      const [msgs,setMsgs]=useState(()=>(SEED[key]||[]).slice().reverse());
      const [input,setInput]=useState("");
      const [myPred,setMyPred]=useState(null);
      const [,setTick]=useState(0);
      const inputRef=useRef(null);
      useEffect(()=>{const t=setInterval(()=>setTick(x=>x+1),1000);return()=>clearInterval(t);},[]);
      const send=()=>{
        if(!input.trim()) return;
        setMsgs(p=>[{id:Date.now(),nick:"Sen",pred:myPred,msg:input,ts:Date.now(),pro:false},...p]);
        setInput(""); inputRef.current&&inputRef.current.focus();
      };
      return (
        <div style={{display:"flex",flexDirection:"column",height:"100%",background:C.bg}}>
          {matchId && (
            <div style={{padding:"10px 14px",borderBottom:"1px solid "+C.border,background:C.card,flexShrink:0}}>
              <div style={{fontSize:10,fontWeight:700,color:C.muted,letterSpacing:1,marginBottom:8}}>TAHMİNİNİ SEÇ</div>
              <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                {PRED_OPTS.map(p=>(
                  <button key={p.key} onClick={()=>setMyPred(myPred===p.key?null:p.key)} style={{padding:"6px 12px",borderRadius:6,cursor:"pointer",border:"1.5px solid "+(myPred===p.key?p.color:C.border),background:myPred===p.key?p.color:C.card,color:myPred===p.key?"#fff":C.muted,fontSize:12,fontWeight:700,fontFamily:"'Nunito Sans',sans-serif"}}>{p.label}</button>
                ))}
              </div>
            </div>
          )}
          <div style={{flex:1,overflowY:"auto",padding:"12px 14px",display:"flex",flexDirection:"column",gap:12}}>
            {msgs.map(m=>(
              <div key={m.id} style={{paddingBottom:12,borderBottom:"1px solid "+C.border}}>
                <div style={{display:"flex",alignItems:"center",gap:7,marginBottom:5,flexWrap:"wrap"}}>
                  <div style={{width:30,height:30,borderRadius:"50%",background:"linear-gradient(135deg,#dbeafe,#bfdbfe)",border:"1.5px solid #93c5fd",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:800,color:"#1d4ed8",flexShrink:0}}>{m.nick[0]}</div>
                  <span style={{fontSize:13,fontWeight:800,color:m.pro?C.gold:C.text,fontFamily:"'Nunito Sans',sans-serif"}}>
                    {m.nick}
                    {m.pro && <span style={{marginLeft:5,fontSize:9,background:C.gold,color:"#fff",padding:"1px 5px",borderRadius:4,fontWeight:800}}>PRO</span>}
                  </span>
                  {m.pred && <span style={{fontSize:10,fontWeight:800,padding:"3px 9px",borderRadius:5,background:PC(m.pred),color:"#fff",fontFamily:"'Oswald',sans-serif"}}>{PL(m.pred)}</span>}
                  <span style={{marginLeft:"auto",fontSize:11,color:C.muted,flexShrink:0}}>{timeAgo(m.ts)}</span>
                </div>
                <div style={{marginLeft:38,fontSize:14,color:"#374151",lineHeight:1.5,fontFamily:"'Nunito Sans',sans-serif"}}>{m.msg}</div>
              </div>
            ))}
          </div>
          <div style={{padding:"10px 12px",borderTop:"1px solid "+C.border,background:C.card,flexShrink:0}}>
            <div style={{display:"flex",gap:8,alignItems:"center"}}>
              <input ref={inputRef} value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==="Enter"&&send()} placeholder="Yorum yaz..." style={{flex:1,background:C.sub,border:"1.5px solid "+C.border,borderRadius:24,padding:"10px 16px",fontSize:14,outline:"none",fontFamily:"'Nunito Sans',sans-serif",color:C.text}}/>
              <button onClick={send} style={{width:42,height:42,borderRadius:"50%",border:"none",background:C.accent,color:"#fff",fontSize:18,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>➤</button>
            </div>
          </div>
        </div>
      );
    }

    function StatsTab({match}) {
